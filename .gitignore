# See https://help.github.com/ignore-files/ for more about ignoring files.

# editors
.idea/
*.iml
.vscode/

# dependencies
/node_modules

# testing
/coverage
/coverage-temp
/test-results

# production
/build

# misc
.DS_Store
.eslintcache

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
*.lnk
$RECYCLE.BIN/

# Environment files
.env
.env.*
.env-archive/
# Supabase configuration
supabase/.env
supabase/functions/.env

# Backup files - should not be tracked
*.bak
*.backup
*.old

npm-debug.log*
yarn-debug.log*
yarn-error.log*
supabase/.branches
supabase/.temp

dist/
/lib/
*storybook.log

# MCP Configuration (contains API keys)
.mcp.json

# Claude memory database (local to each developer)
*.db
*.db-journal
*.db-wal

# But DO track commands and config
!.claude/commands/

storybook-static

# Debug scripts (may contain credentials)
debug-*.js
debug-*.ts
troubleshoot-*.cjs
troubleshoot-*.js

# Screenshot artifacts (debugging)
*.png
!public/**/*.png
!docs/**/*.png

# Temporary/one-time documentation
*-ANALYSIS.md
*-GUIDE.md
*-SUMMARY.md
*_TEST.md

# Backup and sync operation files
backups/
*.sql.backup
logs/sync-operations/
scripts/dev/test-fetch.mjs

# Data files (binary files, spreadsheets, etc.)
data/

# Supabase seed files with real user data
supabase/cloud_users.sql
.vercel

# Git worktrees (isolated development workspaces)
.worktrees/

# Claude Code session files
.claude/checkpoint-state
.claude/memory-capture.log
.claude/settings.local.json
# Drawbridge annotation files (visual UI feedback tool)
.moat/
moat-tasks.md
moat-tasks-detail.json
screenshots/

# Claude Code session caches (keep commands/ and skills/)
.claude/tsc-cache/
.claude/agents/
.agents/
.claude/hooks/
.claude/troubleshooting/
.claude-backup-*.tar.gz

# Build caches
tsconfig.tsbuildinfo

# Temp/test output
test-output.txt

# Windows /dev/null artifact
nul

# Binary business reference files (Excel, PDF, Word)
docs/activitytrackerform/
